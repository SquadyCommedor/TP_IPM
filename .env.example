# ============================================
# SUPABASE CONFIGURATION
# ============================================
# 1. Vai a https://supabase.com/dashboard
# 2. Abre o teu projeto
# 3. Vai a Project Settings → API
# 4. Copia os valores abaixo:

VITE_SUPABASE_URL=https://teu-projeto-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NOTA: Substitui os valores acima pelos teus!
# NUNA partilhes a service_role key!
